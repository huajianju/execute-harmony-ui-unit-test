@@ -0,0 +1,60 @@
+import { describe, it, expect, Level, beforeEach, afterEach } from '@ohos/hypium';
+import { Driver, ON } from '@kit.TestKit';
+import {
+  startAbility, isSameStatusBarColor, getMainWindow,
+  getComponentRectInfoById,
+  ComponentRectInfo,
+  getStatusBarRect,
+  CustomRect,
+  getBundleName,
+} from './TestHelper';
+import {  window } from '@kit.ArkUI';
+
+export default function immersiveStatusBarFailToPassTest() {
+  describe('immersiveStatusBarFailToPassTest', () => {
+    let driver: Driver;
+    let win: window.Window;
+
+    beforeEach(async () => {
+      try {
+        driver = Driver.create();
+        await startAbility(driver, getBundleName(), 'EntryAbility');
+        await driver.delayMs(2000);
+        win = await getMainWindow();
+      } catch (e) {
+        console.error('MineLikePageOrientationUI beforeAll error: ' + JSON.stringify(e));
+      }
+    });
+
+    afterEach(async () => {
+      try {
+        await driver.waitForIdle(2000, 3000);
+        await driver.pressBack();
+      } catch (e) {
+        console.error('MineLikePageOrientationUI afterAll error: ' + JSON.stringify(e));
+      }
+    });
+
+    it('should_content_area_not_overlap_status_bar', Level.LEVEL2, async (done: Function) => {
+      await driver.waitForComponent(ON.type('Navigation'), 3000)
+
+      // 获取状态栏的RectInfo
+      const statusBarRectInfo: CustomRect = getStatusBarRect(win);
+
+      // 获取内容区域头部组件的RectInfo，
+      const headerRectInfo: ComponentRectInfo = getComponentRectInfoById(win, 'CommonHeader')
+
+      // 判断头部组件Rect的y值和状态栏的高度一样
+      expect(headerRectInfo.y).assertEqual(statusBarRectInfo.height);
+      // 验证状态栏避让区域存在，高度大于0
+      expect(statusBarRectInfo.height).assertLarger(0);
+      // 验证头部组件底部完全在状态栏之下
+      expect(headerRectInfo.y + headerRectInfo.height).assertLarger(statusBarRectInfo.height);
+
+      // 判断状态栏区域与紧邻内容区域背景色一致，实现沉浸式效果
+      let result = await isSameStatusBarColor(driver, statusBarRectInfo.height);
+      expect(result).assertTrue();
+      done();
+    });
+  });
+}
